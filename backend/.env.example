# ===========================================
# Backend Environment Variables
# ===========================================
# Copy to .env and fill in values

# -------------------------------------------
# Database (PostgreSQL via Prisma)
# -------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/law_practice_crm?schema=public"

# -------------------------------------------
# Application
# -------------------------------------------
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# -------------------------------------------
# Authentication (Static Admin - MVP)
# -------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-here
JWT_REFRESH_EXPIRES_IN=7d

# -------------------------------------------
# CORS
# -------------------------------------------
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# -------------------------------------------
# File Uploads
# -------------------------------------------
UPLOAD_DESTINATION=./uploads
UPLOAD_MAX_SIZE=10485760

# -------------------------------------------
# Rate Limiting
# -------------------------------------------
THROTTLE_TTL=60000
THROTTLE_LIMIT=100